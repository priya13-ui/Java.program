import java.applet.Applet;
import java.awt.*;

/*
<applet code="FontColorApplet" width="500" height="300">
</applet>
*/

public class FontColorApplet extends Applet {

    public void paint(Graphics g) {

        // First Message - Red, Bold, Large
        Font f1 = new Font("Arial", Font.BOLD, 24);
        g.setFont(f1);
        g.setColor(Color.RED);
        g.drawString("Welcome to Java Applet", 50, 80);

        // Second Message - Blue, Italic, Medium
        Font f2 = new Font("Times New Roman", Font.ITALIC, 20);
        g.setFont(f2);
        g.setColor(Color.BLUE);
        g.drawString("Learning Graphics Programming", 50, 130);

        // Third Message - Green, Plain, Small
        Font f3 = new Font("Courier", Font.PLAIN, 16);
        g.setFont(f3);
        g.setColor(Color.GREEN);
        g.drawString("Different Fonts and Colors", 50, 180);
    }
}
